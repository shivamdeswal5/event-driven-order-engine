{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "transformIgnorePatterns": [
    "/node_modules/(?!@faker-js/)"
  ],
  "moduleNameMapper": {
    "^@shared/(.*)$": "<rootDir>/../modules/shared/src/$1",
    "^@order/(.*)$": "<rootDir>/../modules/order/src/$1",
    "^@inventory/(.*)$": "<rootDir>/../modules/inventory/src/$1",
    "^@payment/(.*)$": "<rootDir>/../modules/payment/src/$1",
    "^@shipping/(.*)$": "<rootDir>/../modules/shipping/src/$1",
    "^@notification/(.*)$": "<rootDir>/../modules/notification/src/$1"
  }
}
