# Application
APP_PORT=8080
APP_FORWARD_PORT=8080
NODE_ENV=development

# PGAdmin credentials
PGADMIN_FORWARD_PORT=8888
PGADMIN_DEFAULT_EMAIL=admin@gmail.com
PGADMIN_DEFAULT_PASSWORD=deswal

# Database

DB_HOST=order-engine-database
DB_PORT=5432
DB_NAME=order_engine
DB_USER=deswal
DB_PASSWORD=deswal

# Per-module schemas
DB_SCHEMA_SHARED=shared_schema
DB_SCHEMA_ORDER=order_schema
DB_SCHEMA_INVENTORY=inventory_schema
DB_SCHEMA_PAYMENT=payment_schema
DB_SCHEMA_SHIPPING=shipping_schema
DB_SCHEMA_NOTIFICATION=notification_schema

# RabbitMQ
RABBITMQ_URL=amqp://deswal:deswal@rabbitmq:5672
RABBITMQ_MANAGEMENT_URL=http://rabbitmq:15672
RABBITMQ_USER=deswal
RABBITMQ_PASSWORD=deswal
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_MAX_RETRIES=3
OUTBOX_POLLING_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=100

# ─── RabbitMQ Advanced Configurations (Optional Overrides) ─────────────────────
# Expose parameters to override default per-module topologies and retry policies.
#
# Custom central exchange names (defaults to per-module, e.g. 'order-exchange')
# RABBITMQ_TOPIC_EXCHANGE=order-engine-topic
# RABBITMQ_DIRECT_EXCHANGE=order-engine-direct
#
# Custom retry settings (defaults: immediate=3, delayed=3, TTL=5000ms)
# RABBITMQ_IMMEDIATE_RETRIES=3
# RABBITMQ_DELAYED_RETRIES=3
# RABBITMQ_RETRY_QUEUE_MESSAGE_TTL=5000
#
# Concurrency tuning (defaults: consume=10, dispatch=10)
# RABBITMQ_CONSUME_MESSAGE_LIMIT=10
# RABBITMQ_DISPATCH_MESSAGE_LIMIT=10
