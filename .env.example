# Application
APP_PORT=8080
APP_FORWARD_PORT=8082
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# All modules share one database, each isolated in its own PostgreSQL schema.
# Schema names must match what MikroORM contextName derives: e.g. 'order' → 'order_schema'
DB_HOST=postgres
DB_PORT=5432
DB_NAME=order_engine
DB_USER=order_user
DB_PASSWORD=order_pass

# Per-module schemas (used by @Entity decorator for runtime query qualification)
DB_SCHEMA_SHARED=shared_schema
DB_SCHEMA_ORDER=order_schema
DB_SCHEMA_INVENTORY=inventory_schema
DB_SCHEMA_PAYMENT=payment_schema
DB_SCHEMA_SHIPPING=shipping_schema
DB_SCHEMA_NOTIFICATION=notification_schema

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://rabbit_user:rabbit_pass@rabbitmq:5672
RABBITMQ_MANAGEMENT_URL=http://rabbitmq:15672
RABBITMQ_USER=rabbit_user
RABBITMQ_PASSWORD=rabbit_pass
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_MAX_RETRIES=3

# ─── Outbox Relay ─────────────────────────────────────────────────────────────
OUTBOX_POLLING_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=100
