{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@shared/*": ["modules/shared/src/*"],
      "@order/*": ["modules/order/src/*"],
      "@inventory/*": ["modules/inventory/src/*"],
      "@payment/*": ["modules/payment/src/*"],
      "@shipping/*": ["modules/shipping/src/*"],
      "@notification/*": ["modules/notification/src/*"]
    }
  }
}
